---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#231f20" />
    <meta
      name="description"
      content="Allroven está construyendo una nueva experiencia digital."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon-allroven-accent.png" />
    <title>Allan Rodríguez | En construcción</title>
  </head>
  <body>
    <main class="construction">
      <div class="construction__content">
        <img
          class="construction__logo"
          src="/logo-allroven.png"
          alt="Isotipo de Allan Rodríguez"
          width="1080"
          height="1080"
        />

        <div class="construction__message">
          <p class="construction__status">
            <span aria-hidden="true"></span>
            Actualmente en construcción
          </p>
          <h1>Portafolio<br />profesional<span aria-hidden="true">.</span></h1>
          <p class="construction__description">
            <span>Estamos construyendo un espacio para compartir proyectos e ideas.</span>
            <span>Soluciones tecnológicas que mejoran vidas.</span>
          </p>
        </div>
      </div>

      <footer class="construction__footer">
        <span>allroven.me</span>
        <a href="mailto:allroven@gmail.com">
          allroven@gmail.com
        </a>
      </footer>
    </main>
  </body>
</html>
